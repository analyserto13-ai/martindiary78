{
  "expo": {
    "name": "Martin78 Diary",
    "slug": "Martin78Diary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "martin78diary",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.martin78.diary",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Martin78 Diary to access your photo library to add photos to diary entries.",
        "NSCameraUsageDescription": "Allow Martin78 Diary to use the camera to take photos for diary entries.",
        "NSUserNotificationsUsageDescription": "Allow Martin78 Diary to send you reminders for your diary entries."
      }
    },
    "android": {
      "package": "com.martin78.diary",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#303F9F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-image-picker",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "owner": ""
  }
}